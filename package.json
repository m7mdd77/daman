{
  "name": "daman",
  "version": "0.1.0",
  "private": true,
  "description": "Trustless handoff escrow for deals made in DMs, built on Monad.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "hardhat test",
    "contract:compile": "hardhat compile",
    "contract:export": "node scripts/export-deployment-artifact.cjs",
    "contract:deploy:testnet": "hardhat run scripts/deploy.cjs --network monadTestnet",
    "contract:deploy:mainnet": "hardhat run scripts/deploy.cjs --network monadMainnet",
    "contract:verify:testnet": "hardhat verify --network monadTestnet",
    "contract:verify:mainnet": "hardhat verify --network monadMainnet"
  },
  "dependencies": {
    "@fontsource-variable/manrope": "^5.2.8",
    "lucide-react": "^0.468.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "viem": "^2.21.57"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "dotenv": "^16.4.7",
    "hardhat": "^2.22.17",
    "typescript": "~5.6.3",
    "vite": "^6.0.5"
  },
  "packageManager": "pnpm@10.4.1"
}
